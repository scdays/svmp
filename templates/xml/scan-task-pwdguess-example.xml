<?xml version="1.0" encoding="UTF-8"?>
<ScanTask>
  <task>
    <taskName><![CDATA[2026Q2-口令猜测]]></taskName>
    <priority>MEDIUM</priority>
  </task>
  <targets>
    <target>
      <ip><![CDATA[10.10.1.1]]></ip>
    </target>
    <target>
      <ip><![CDATA[10.10.1.2]]></ip>
    </target>
  </targets>
  <scanTemplate>
    <liveProbe enabled="true">
      <icmp>true</icmp>
      <tcp>true</tcp>
