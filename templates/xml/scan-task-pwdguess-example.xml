<?xml version="1.0" encoding="UTF-8"?>
<!--
  开放平台 · 扫描任务配置（口令猜测 type=3，§5.1.1）
  scanTemplateId=0：Partner 在 scanPolicy 中自行填写各扫描阶段
-->
<ScanTask>
  <targets>
    <target>10.10.1.1</target>
    <target>10.10.1.2</target>
  </targets>
  <scanTemplateId>0</scanTemplateId>
  <reportTemplateId>2001</reportTemplateId>
  <priority>MEDIUM</priority>
  <scanPolicy>
    <liveProbe enabled="true">
      <icmp>true</icmp>
      <tcp>true</tcp>
      <tcpPorts>21,22,80,443</tcpPorts>
    </liveProbe>
    <pwdGuess enabled="true">
      <threadNum>5</threadNum>
      <timeoutSec>30</timeoutSec>
      <services>
        <service protocol="SSH" ports="22"/>
        <service protocol="SMB" ports="139,445"/>
        <service protocol="TELNET" ports="23"/>
      </services>
    </pwdGuess>
  </scanPolicy>
</ScanTask>
