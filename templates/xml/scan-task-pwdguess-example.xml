<?xml version="1.0" encoding="UTF-8"?>
<!--
  开放平台 · 模式 B：口令猜测 type=3，内联 scanTemplate/reportTemplate
-->
<ScanTask>
  <targets>
    <target>
      <ip><![CDATA[10.10.1.1]]></ip>
    </target>
    <target>
      <ip><![CDATA[10.10.1.2]]></ip>
    </target>
  </targets>
  <priority>MEDIUM</priority>
  <scanTemplate>
    <liveProbe enabled="true">
      <icmp>true</icmp>
      <tcp>true</tcp>
      <tcpPorts>21,22,80,443</tcpPorts>
    </liveProbe>
    <pwdGuess enabled="true">
      <threadNum>5</threadNum>
      <timeoutSec>30</timeoutSec>
      <services>
        <service protocol="SSH" ports="22"/>
        <service protocol="SMB" ports="139,445"/>
        <service protocol="TELNET" ports="23"/>
      </services>
    </pwdGuess>
  </scanTemplate>
  <reportTemplate>
    <format>json</format>
    <dataProfile>MIXED</dataProfile>
  </reportTemplate>
</ScanTask>
