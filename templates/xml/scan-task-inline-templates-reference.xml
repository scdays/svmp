<?xml version="1.0" encoding="UTF-8"?>
<!--
  开放平台 · 内联 scanTemplate / reportTemplate 全量结构参考（附录 H，§5.1.1 模式 B）
-->
<ScanTask>
  <targets>
    <target>10.10.1.1</target>
  </targets>
  <priority>MEDIUM</priority>
  <scanTemplate>
    <liveProbe enabled="true">
      <icmp>true</icmp>
      <tcp>true</tcp>
      <tcpPorts>21,22,80,443,3389</tcpPorts>
    </liveProbe>
    <portScan enabled="true">
      <strategy>standard</strategy>
      <userPorts>1-65535</userPorts>
      <tcpMode>SYN</tcpMode>
      <udpEnabled>false</udpEnabled>
    </portScan>
    <vulnScan enabled="true">
      <depth>3</depth>
      <expVerify>false</expVerify>
    </vulnScan>
    <pwdGuess enabled="false">
      <threadNum>5</threadNum>
      <timeoutSec>30</timeoutSec>
      <services>
        <service protocol="SSH" ports="22"/>
      </services>
    </pwdGuess>
  </scanTemplate>
  <reportTemplate>
    <format>xml</format>
    <dataProfile>MIXED</dataProfile>
  </reportTemplate>
</ScanTask>
