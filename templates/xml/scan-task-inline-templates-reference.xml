<?xml version="1.0" encoding="UTF-8"?>
<scanTask>
  <server>
    <taskName><![CDATA[server 内联扫描策略与 report 结构参考]]></taskName>
    <priority>MEDIUM</priority>
    <targets><![CDATA[10.10.1.1]]></targets>
    <liveProbe enabled="true">
      <icmp>true</icmp>
      <tcp>true</tcp>
      <tcpPorts>1-65535</tcpPorts>
    </liveProbe>
    <portScan enabled="true">
      <strategy>standard</strategy>
      <userPorts>1-65535</userPorts>
      <tcpMode>SYN</tcpMode>
      <udpEnabled>false</udpEnabled>
    </portScan>
    <vulnScan enabled="true">
      <depth>3</depth>
      <expVerify>false</expVerify>
    </vulnScan>
    <pwdGuess enabled="false">
      <threadNum>5</threadNum>
      <timeoutSec>30</timeoutSec>
      <services>
        <service protocol="SSH" ports="22"/>
      </services>
    </pwdGuess>
  </server>
  <targets/>
  <report>
    <format>xml</format>
    <dataProfile>MIXED</dataProfile>
  </report>
</scanTask>
